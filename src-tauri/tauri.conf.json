{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OVERCLOCK",
  "version": "0.1.0",
  "identifier": "com.overclock.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OVERCLOCK",
        "width": 800,
        "height": 600,
        "minWidth": 700,
        "minHeight": 500,
        "decorations": false,
        "center": true,
        "resizable": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
